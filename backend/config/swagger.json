{
  "openapi": "3.0.0",
  "info": {
    "title": "GREEN AGRIC API",
    "version": "1.0.0",
    "description": "Backend API & MQTT Service cho hệ thống nông nghiệp thông minh"
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    { "bearerAuth": [] }
  ],
  "paths": {

    "/auth/login": {
      "post": {
        "summary": "Đăng nhập",
        "security": [],
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Đăng nhập thành công" }
        }
      }
    },

    "/area": {
      "get": {
        "summary": "Lấy danh sách khu vực",
        "tags": ["Area"],
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "summary": "Thêm khu vực",
        "tags": ["Area"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" },
                  "owner_id": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Created" } }
      }
    },

    "/area/{id}": {
      "put": {
        "summary": "Cập nhật khu vực",
        "tags": ["Area"],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated" }
        }
      },
      "delete": {
        "summary": "Xóa khu vực",
        "tags": ["Area"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Deleted" } }
      }
    },

    "/sensor": {
      "get": {
        "summary": "Lấy tất cả cảm biến",
        "tags": ["Sensor"],
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "summary": "Thêm cảm biến",
        "tags": ["Sensor"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "type": { "type": "string" },
                  "area_id": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Created" } }
      }
    },

    "/sensor/{id}": {
      "put": {
        "summary": "Cập nhật cảm biến",
        "tags": ["Sensor"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "type": { "type": "string" },
                  "area_id": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "summary": "Xóa cảm biến",
        "tags": ["Sensor"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Deleted" } }
      }
    },

    "/sensor/area/{area_id}/latest": {
      "get": {
        "summary": "Dữ liệu cảm biến mới nhất theo khu vực",
        "tags": ["Sensor"],
        "parameters": [
          { "name": "area_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },

    "/sensor/area/{area_id}/history/{type}": {
      "get": {
        "summary": "Lịch sử cảm biến theo loại",
        "tags": ["Sensor"],
        "parameters": [
          { "name": "area_id", "in": "path", "required": true, "schema": { "type": "integer" } },
          { "name": "type", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },

    "/sensor/data": {
      "post": {
        "summary": "Thêm dữ liệu cảm biến",
        "tags": ["Sensor"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "sensor_id": { "type": "integer" },
                  "value": { "type": "number" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Created" } }
      }
    },

    "/device": {
      "get": {
        "summary": "Lấy danh sách thiết bị",
        "tags": ["Device"],
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "summary": "Thêm thiết bị",
        "tags": ["Device"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "type": { "type": "string" },
                  "area_id": { "type": "integer" },
                  "status": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Created" } }
      }
    },

    "/device/{id}": {
      "put": {
        "summary": "Cập nhật thiết bị",
        "tags": ["Device"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "type": { "type": "string" },
                  "status": { "type": "integer" },
                  "area_id": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "summary": "Xóa thiết bị",
        "tags": ["Device"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Deleted" } }
      }
    },

    "/device/override": {
      "post": {
        "summary": "Điều khiển thiết bị thủ công",
        "tags": ["Device"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "device_id": { "type": "integer" },
                  "mode": { "type": "string", "enum": ["ON", "OFF"] },
                  "expire_time": {
                    "type": "string",
                    "format": "date-time"
                  }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },

    "/activity": {
      "get": {
        "summary": "Lấy lịch sử hoạt động của các thiết bị",
        "tags": ["Activity"],
        "responses": { "200": { "description": "OK" } }
      }
    },

    "/activity/{device_id}": {
      "get": {
        "summary": "Lấy lịch sử hoạt động theo 1 thiết bị cụ thể",
        "tags": ["Activity"],
        "parameters": [
          { "name": "device_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },

    "/threshold": {
      "post": {
        "summary": "Thiết lập ngưỡng",
        "tags": ["Threshold"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "area_id": { "type": "integer" },
                  "sensor_type": { "type": "string" },
                  "min_value": { "type": "number" },
                  "max_value": { "type": "number" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },

    "/threshold/{area_id}": {
      "get": {
        "summary": "Lấy cấu hình ngưỡng của 1 khu vực",
        "tags": ["Threshold"],
        "parameters": [
          { "name": "area_id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },

    "/notification": {
      "get": {
        "summary": "Lấy danh sách thông báo",
        "tags": ["Notification"],
        "responses": { "200": { "description": "OK" } }
      }
    },

    "/notification/{id}/read": {
      "post": {
        "summary": "Đánh dấu thông báo đã đọc",
        "tags": ["Notification"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },

    "/user": {
      "get": {
        "summary": "Lấy danh sách user",
        "tags": ["User"],
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "summary": "Thêm người dùng mới (Admin)",
        "tags": ["User"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" },
                  "name": { "type": "string" },
                  "role": { "type": "string", "enum": ["admin", "owner", "staff"] },
                  "email": { "type": "string" },
                  "phone": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Created" } }
      }
    },

    "/user/profile": {
      "get": {
        "summary": "Lấy thông tin user hiện tại",
        "tags": ["User"],
        "responses": { "200": { "description": "OK" } }
      },
      "put": {
        "summary": "Cập nhật thông tin cá nhân",
        "tags": ["User"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string",
                    "example": "nguyenvana"
                  },
                  "name": {
                    "type": "string",
                    "example": "Nguyễn Văn A"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "example@gmail.com"
                  },
                  "phone": {
                    "type": "string",
                    "example": "0988123456"
                  }
                },
                "additionalProperties": false
              }
            }
          }
        },
        "responses": { "200": { "description": "Updated" } }
      }
    },

    "/user/{id}": {
      "put": {
        "summary": "Chỉnh sửa thông tin người dùng (Admin)",
        "tags": ["User"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "minProperties": 1,
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "Nguyễn Văn A"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "example@gmail.com"
                  },
                  "phone": {
                    "type": "string",
                    "example": "0988123456"
                  },
                  "role": {
                    "type": "string",
                    "enum": ["admin", "owner", "staff"],
                    "example": "owner"
                  },
                  "password": {
                    "type": "string",
                    "example": "newpassword123"
                  }
                },
                "additionalProperties": false
              }
            }
          }
        },
        "responses": { "200": { "description": "Updated" } }
      },
      "delete": {
        "summary": "Xóa người dùng (Admin)",
        "tags": ["User"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "Deleted" } }
      }
    },

    "/task": {
      "get": {
        "summary": "Lấy danh sách các công việc cần làm",
        "tags": [
          "Task"
        ],
        "responses": {
          "200": {
            "description": "Thành công"
          }
        }
      },
      "post": {
        "summary": "Thêm một công việc mới",
        "tags": [
          "Task"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "example": "Bón phân định kỳ"
                  },
                  "description": {
                    "type": "string",
                    "example": "Bón phân hữu cơ"
                  },
                  "scheduled_at": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2026-05-15T15:00:00Z"
                  },
                  "area_id": {
                    "type": "integer",
                    "example": 1
                  },
                  "status": {
                    "type": "string",
                    "default": "pending"
                  },
                  "is_done": {
                    "type": "boolean",
                    "default": false
                  }
                },
                "required": [
                  "title"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tạo công việc thành công"
          }
        }
      }
    },
    
    "/task/{id}": {
      "put": {
        "summary": "Cập nhật công việc",
        "tags": [
          "Task"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "title": {
                    "type": "string",
                    "example": "Kiểm tra nồng độ dinh dưỡng"
                  },
                  "scheduled_at": {
                    "type": "string",
                    "format": "date-time",
                    "example": "2026-04-28T15:22:58.693Z"
                  },
                  "status": {
                    "type": "string",
                    "example": "PENDING"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cập nhật công việc thành công"
          }
        }
      },
      "delete": {
        "summary": "Xóa công việc",
        "tags": [
          "Task"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Xóa công việc thành công"
          },
          "404": {
            "description": "Không tìm thấy công việc hoặc bạn không có quyền xóa"
          },
          "500": {
            "description": "Lỗi server nội bộ"
          }
        }
      }
    },
    "/task/{id}/status": {
      "patch": {
        "summary": "Cập nhật trạng thái công việc",
        "tags": [
          "Task"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "example": "COMPLETED"
                  }
                },
                "required": [
                  "status"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Cập nhật trạng thái thành công"
          }
        }
      }
    }
  }
}